"""
Entry point for the genome comparison pipeline.

Genome-agnostic by design: it processes whatever genomes are listed in
config/genomes.tsv, computing protein + CDS properties, cross-genome summaries,
and figures for each. The current example dataset happens to be 9 red algae
from a lifestyle-comparison study, but nothing here assumes that -- point
genome_table and the input directories at a different set of genomes/proteomes
and the same rules apply unchanged.

Snakemake reads this file top-to-bottom to build its rule graph:
  1. `configfile:` loads config/config.yaml into the global `config` dict.
  2. We read config/genomes.tsv to get the list of genome IDs -- this becomes the
     set of values Snakemake will substitute for the `{genome}` wildcard.
  3. `rule all` lists every *final* output we want. Snakemake works backwards from
     there: for each missing file, it looks for a rule whose `output` matches, then
     recurses into *that* rule's `input`, and so on, until every input either exists
     or there's no rule left that could produce it. That backwards search is how the
     DAG (directed acyclic graph) of jobs gets built -- you never say "run qc, then
     parse, then..." yourself, you just declare each rule's input/output and
     Snakemake figures out the order and what can run in parallel.
  4. `include:` pulls in the actual rule definitions from workflow/rules/*.smk.
     Included files share the same namespace as this Snakefile, so they can freely
     use `config`, `OUTDIR`, and `GENOMES` without importing anything.
"""

configfile: "config/config.yaml"

import pandas as pd

genome_df = pd.read_csv(config["genome_table"], sep="\t")
GENOMES = genome_df["genome_id"].tolist()

OUTDIR = config["output_dir"]

rule all:
    # The default target: running plain `snakemake` (no arguments) asks Snakemake to
    # produce this file, which pulls in the entire dependency chain behind it.
    input:
        OUTDIR + "/dashboard/dashboard.done",

include: "rules/qc.smk"
include: "rules/parse.smk"
include: "rules/protein_properties.smk"
include: "rules/cds_properties.smk"
include: "rules/summaries.smk"
include: "rules/visuals.smk"
include: "rules/dashboard.smk"
