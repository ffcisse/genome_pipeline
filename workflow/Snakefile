"""
Entry point for the genome comparison pipeline.

Genome-agnostic by design: it processes whatever genomes are listed in
config/genomes.tsv, computing protein + CDS properties, cross-genome summaries,
and figures for each. The current example dataset happens to be 9 red algae
from a lifestyle-comparison study, but nothing here assumes that -- point
genome_table and the input directories at a different set of genomes/proteomes
and the same rules apply unchanged.

Snakemake reads this file top-to-bottom to build its rule graph:
  1. `configfile:` loads config/config.yaml into the global `config` dict.
  2. We read config/genomes.tsv to get the list of genome IDs -- this becomes the
     set of values Snakemake will substitute for the `{genome}` wildcard.
  3. `rule all` lists every *final* output we want. Snakemake works backwards from
     there: for each missing file, it looks for a rule whose `output` matches, then
     recurses into *that* rule's `input`, and so on, until every input either exists
     or there's no rule left that could produce it. That backwards search is how the
     DAG (directed acyclic graph) of jobs gets built -- you never say "run qc, then
     parse, then..." yourself, you just declare each rule's input/output and
     Snakemake figures out the order and what can run in parallel.
  4. `include:` pulls in the actual rule definitions from workflow/rules/*.smk.
     Included files share the same namespace as this Snakefile, so they can freely
     use `config`, `OUTDIR`, and `GENOMES` without importing anything.
"""

configfile: "config/config.yaml"

import glob
import os

import pandas as pd

genome_df = pd.read_csv(config["genome_table"], sep="\t")
GENOMES = genome_df["genome_id"].tolist()

OUTDIR = config["output_dir"]

# ---- Resolve staged input paths ----
# PROTEIN_STAGED / CDS_STAGED map genome_id -> the file qc/parse should read.
# Default (no staging configured): protein_dir/cds_dir already contain flat
# "<genome_id>.fasta" files -- the pipeline's baseline contract.
#
# With staging.source_dir set, real files live nested under
# source_dir/<protein_subdir>/<cds_subdir>/<genome_id>/**/*.fasta* with
# varying extensions (.fasta.gz or .fasta.tar.gz -- see config.yaml). We
# resolve the real extension now, from source_dir (which already exists on
# disk, regardless of whether stage_inputs has run yet), so the staged path
# -- and therefore every rule's input -- is known at DAG-build time without
# needing a Snakemake checkpoint.
PROTEIN_DIR = config["input"]["protein_dir"]
CDS_DIR = config["input"]["cds_dir"]
_staging_config = config.get("staging", {})
STAGING_SOURCE_DIR = _staging_config.get("source_dir")
STAGING_PROTEIN_SUBDIR = _staging_config.get("protein_subdir", "proteome_files")
STAGING_CDS_SUBDIR = _staging_config.get("cds_subdir", "cds_files")


def _discover_source(category, genome):
    """Find the single real FASTA (any *.fasta* extension) for one genome
    under source_dir/<category>/<genome>/, and return (path, extension)."""
    pattern = os.path.join(STAGING_SOURCE_DIR, category, genome, "**", "*.fasta*")
    matches = sorted(glob.glob(pattern, recursive=True))
    if len(matches) != 1:
        raise ValueError(
            f"Expected exactly one *.fasta* file for genome '{genome}' under "
            f"{os.path.join(STAGING_SOURCE_DIR, category, genome)}, found {len(matches)}: {matches}"
        )
    src = matches[0]
    ext = src[src.index(".fasta"):]
    return src, ext


if STAGING_SOURCE_DIR:
    PROTEIN_SOURCE, CDS_SOURCE = {}, {}
    PROTEIN_STAGED, CDS_STAGED = {}, {}
    for _genome in GENOMES:
        psrc, pext = _discover_source(STAGING_PROTEIN_SUBDIR, _genome)
        csrc, cext = _discover_source(STAGING_CDS_SUBDIR, _genome)
        PROTEIN_SOURCE[_genome] = psrc
        CDS_SOURCE[_genome] = csrc
        PROTEIN_STAGED[_genome] = f"{PROTEIN_DIR}/{_genome}{pext}"
        CDS_STAGED[_genome] = f"{CDS_DIR}/{_genome}{cext}"
else:
    PROTEIN_STAGED = {g: f"{PROTEIN_DIR}/{g}.fasta" for g in GENOMES}
    CDS_STAGED = {g: f"{CDS_DIR}/{g}.fasta" for g in GENOMES}

rule all:
    # The default target: running plain `snakemake` (no arguments) asks Snakemake to
    # produce this file, which pulls in the entire dependency chain behind it.
    input:
        OUTDIR + "/dashboard/dashboard.done",

if STAGING_SOURCE_DIR:
    include: "rules/staging.smk"
include: "rules/qc.smk"
include: "rules/parse.smk"
include: "rules/protein_properties.smk"
include: "rules/cds_properties.smk"
include: "rules/summaries.smk"
include: "rules/visuals.smk"
include: "rules/dashboard.smk"
